{
  "expo": {
    "name": "SIPO Mobile",
    "slug": "sipoApp",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon-shadow.png",
    "scheme": "sipo-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "buildNumber": "3",
      "supportsTablet": true,
      "bundleIdentifier": "com.reka.sipoapp",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "versionCode": 3,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-shadow.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.reka.sipoapp",
      "permissions": [
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-sipo-2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon-shadow.png",
          "color": "#0B3B82",
          "sounds": []
        }
      ],
      "expo-web-browser"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5f4848f3-6bce-4af5-b269-f0021407c68b"
      }
    }
  }
}